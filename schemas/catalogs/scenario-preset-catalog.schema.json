            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "node_class": {
            "type": "string"
          },
          "scenario_id_seed": {
            "type": "string"
          },
          "mission_mode_default": {
            "type": "string"
          },
          "architecture_class_default": {
            "type": "string"
          },
          "compute_device_preset_id": {
            "type": "string"
          },
