{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://space-server-heat-dissipation/schemas/catalogs/payload-archetype-catalog.schema.json",
  "schema_id": "payload-archetype-catalog",
  "schema_version": "v0.1.0",
  "title": "PayloadArchetypeCatalog",
  "type": "object",
  "required": [
    "catalog_id",
    "catalog_version",
    "entries"
  ],
  "properties": {
    "catalog_id": {
      "type": "string"
    },
    "catalog_version": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "archetype_id",
          "label",
          "rf_comms_power_w",
          "telemetry_power_w",
          "radar_power_w",
          "optical_crosslink_power_w",
          "default_duty_mode",
          "default_duty_fraction",
          "notes",
          "research_required"
        ],
        "properties": {
          "archetype_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "rf_comms_power_w": {
            "type": "number",
            "minimum": 0
          },
          "telemetry_power_w": {
            "type": "number",
            "minimum": 0
          },
          "radar_power_w": {
            "type": "number",
            "minimum": 0
          },
          "optical_crosslink_power_w": {
            "type": "number",
            "minimum": 0
          },
          "default_duty_mode": {
            "type": "string"
          },
          "default_duty_fraction": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "default_thermal_coupling_zone_ref": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "research_required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}