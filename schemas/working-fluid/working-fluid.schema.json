{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "working-fluid",
  "schema_version": "v0.2.0",
  "title": "WorkingFluid",
  "description": "Working fluid catalog entry. v0.2.0 adds Extension 3A intrinsic numeric properties and provenance fields per 3A-spec \u00a77. Legacy fluid_id field preserved as optional backward-compat. Canonical 3A ID is working_fluid_id. v0.2.0 adds 3B intrinsic gas-management fields per 3B-spec \u00a77.",
  "type": "object",
  "required": [
    "working_fluid_id",
    "schema_version",
    "label",
    "fluid_class",
    "phase_class",
    "temp_operating_min_k",
    "temp_operating_max_k",
    "cp_basis_j_per_kgk",
    "density_basis_kg_per_m3",
    "thermal_conductivity_w_per_mk",
    "viscosity_basis_pa_s",
    "provenance_class",
    "confidence_class",
    "maturity_class",
    "research_required",
    "source_note"
  ],
  "additionalProperties": false,
  "properties": {
    "working_fluid_id": {
      "type": "string",
      "description": "Canonical 3A fluid ID. Referenced by thermal-zone.working_fluid_ref. \u00a77.1."
    },
    "fluid_id": {
      "type": "string",
      "description": "DEPRECATED: legacy baseline fluid ID. Preserved for backward compat with pre-3A entries. Use working_fluid_id for 3A."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "label": {
      "type": "string"
    },
    "fluid_class": {
      "type": "string",
      "enum": [
        "noble_gas",
        "molecular_gas",
        "liquid_metal",
        "phase_change_refrigerant",
        "water_family",
        "custom"
      ],
      "description": "Fluid class per 3A-spec \u00a77.2."
    },
    "medium_class": {
      "type": "string",
      "enum": [
        "gas",
        "liquid",
        "two_phase",
        "liquid_metal",
        "molten_salt",
        "custom"
      ],
      "description": "LEGACY: baseline medium_class field. Preserved for backward compat."
    },
    "phase_class": {
      "type": "string",
      "enum": [
        "single_phase_gas",
        "single_phase_liquid",
        "two_phase_allowed",
        "custom"
      ],
      "description": "Phase class per 3A-spec \u00a77.3."
    },
    "intended_use_domain": {
      "type": "string",
      "enum": [
        "cold_loop",
        "hot_backbone",
        "radiator_loop",
        "storage_interface",
        "custom"
      ],
      "description": "LEGACY: baseline intended_use_domain. Preserved for backward compat."
    },
    "temp_operating_min_k": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Operating temperature minimum K. \u00a77.1."
    },
    "temp_operating_max_k": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Operating temperature maximum K. \u00a77.1."
    },
    "temp_min_k": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "LEGACY: alias for temp_operating_min_k."
    },
    "temp_max_k": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "LEGACY: alias for temp_operating_max_k."
    },
    "cp_basis_j_per_kgk": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Specific heat capacity basis J/kg/K. Intrinsic. \u00a77.1."
    },
    "density_basis_kg_per_m3": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Density basis kg/m\u00b3. Intrinsic. \u00a77.1."
    },
    "thermal_conductivity_w_per_mk": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Thermal conductivity W/m/K. Intrinsic. \u00a77.1."
    },
    "viscosity_basis_pa_s": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Dynamic viscosity Pa\u00b7s basis. Intrinsic. \u00a77.1."
    },
    "gamma_ratio": {
      "type": [
        "number",
        "null"
      ],
      "exclusiveMinimum": 0,
      "description": "Specific heat ratio gamma (Cp/Cv). Nullable for non-gases. \u00a77.1."
    },
    "latent_heat_basis_j_per_kg": {
      "type": [
        "number",
        "null"
      ],
      "exclusiveMinimum": 0,
      "description": "Latent heat of vaporization J/kg. Nullable for non-phase-change use. \u00a77.1."
    },
    "provenance_class": {
      "type": "string",
      "enum": [
        "sourced_authoritative",
        "sourced_secondary",
        "operator_estimated",
        "research_required"
      ],
      "description": "Data provenance class per \u00a77.1, \u00a715.1."
    },
    "confidence_class": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ],
      "description": "Confidence class per \u00a77.1."
    },
    "maturity_class": {
      "type": "string",
      "enum": [
        "flight_proven",
        "trl_6_plus",
        "trl_4_5",
        "conceptual",
        "research_required"
      ],
      "description": "Maturity class. Covers legacy and 3A use."
    },
    "research_required": {
      "type": "boolean",
      "description": "Whether further research is required before operational use. \u00a77.1."
    },
    "source_note": {
      "type": "string",
      "description": "Source citation or provenance note. \u00a77.1."
    },
    "default_cp_j_per_kgk": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "LEGACY: baseline cp field. Use cp_basis_j_per_kgk for 3A."
    },
    "default_density_kg_per_m3": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "LEGACY: baseline density field. Use density_basis_kg_per_m3 for 3A."
    },
    "sourcing_status": {
      "type": "string",
      "enum": [
        "operator-estimated",
        "sourced",
        "inferred",
        "research-required"
      ],
      "description": "LEGACY: sourcing status. 3A uses provenance_class."
    },
    "pressure_notes": {
      "type": "string"
    },
    "compatibility_notes": {
      "type": "string"
    },
    "hazards": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "dielectric_relevance": {
      "type": "string",
      "enum": [
        "not_applicable",
        "low",
        "moderate",
        "high",
        "custom"
      ],
      "default": "not_applicable",
      "description": "Bubble and electrical risk interpretation relevance. 3B-spec \u00a77."
    },
    "microgravity_gas_management_notes": {
      "type": "string",
      "default": "",
      "description": "Descriptive microgravity gas management notes. 3B-spec \u00a77."
    }
  }
}