{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "conversion-branch",
  "schema_version": "v0.2.0",
  "title": "ConversionBranch",
  "description": "Optional conversion or export branch. Carnot bounds enforced at runtime per \u00a724.3. UI-expansion additive fields per ui-expansion-spec-v0.1.5. v0.2.0 adds 3B TEG boundedness fields per 3B-spec \u00a78.",
  "type": "object",
  "required": [
    "branch_id",
    "schema_version",
    "branch_type",
    "enabled",
    "mode_label",
    "efficiency_or_cop",
    "output_class",
    "loss_partition_rule",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "branch_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "branch_type": {
      "type": "string",
      "enum": [
        "none",
        "reverse_brayton",
        "brayton_power_cycle",
        "stirling",
        "tpv",
        "teg",
        "rf_export",
        "laser_export",
        "custom"
      ]
    },
    "enabled": {
      "type": "boolean"
    },
    "input_stage_ref": {
      "type": "string"
    },
    "input_zone_ref": {
      "type": "string"
    },
    "mode_label": {
      "type": "string",
      "enum": [
        "heat_lift",
        "power_cycle",
        "electrical_conversion",
        "directed_energy_emission",
        "scavenging"
      ]
    },
    "efficiency_or_cop": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Interpreted as COP for heat-lift, efficiency for power-cycle."
    },
    "output_class": {
      "type": "string",
      "enum": [
        "electrical",
        "thermal_rejected",
        "directed_energy",
        "none"
      ]
    },
    "loss_partition_rule": {
      "type": "string",
      "enum": [
        "all_on_node",
        "proportional",
        "explicit",
        "none"
      ]
    },
    "t_cold_source_k": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "t_hot_delivery_k": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "t_hot_source_k": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "t_cold_sink_k": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "q_dot_input_w": {
      "type": "number",
      "minimum": 0
    },
    "efficiency_fraction": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_zone_ref": {
      "type": "string"
    },
    "sink_zone_ref": {
      "type": "string"
    },
    "requires_work_input": {
      "type": "boolean"
    },
    "allows_external_heat_source": {
      "type": "boolean"
    },
    "work_input_w": {
      "type": "number",
      "minimum": 0
    },
    "external_heat_input_w": {
      "type": "number",
      "minimum": 0
    },
    "storage_drawdown_w": {
      "type": "number",
      "minimum": 0
    },
    "requires_carnot_check": {
      "type": "boolean"
    },
    "label": {
      "type": "string"
    },
    "preset_id": {
      "type": "string"
    },
    "branch_variant": {
      "type": "string",
      "enum": [
        "base",
        "with_regen",
        "solar_polish",
        "custom"
      ]
    },
    "maturity_class": {
      "type": "string"
    },
    "research_required": {
      "type": "boolean"
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "teg_carnot_fraction_cap": {
      "type": [
        "number",
        "null"
      ],
      "exclusiveMinimum": 0,
      "maximum": 1,
      "default": 0.2,
      "description": "Conservative TEG Carnot fraction cap. 0.20 is heuristic, not flight-certainty. 3B-spec \u00a78, \u00a78.1."
    },
    "teg_residual_heat_on_node": {
      "type": [
        "boolean",
        "null"
      ],
      "default": true,
      "description": "When true, TEG residual heat stays in reject bookkeeping on-node. 3B-spec \u00a78."
    },
    "teg_subordinate_to_rejection": {
      "type": [
        "boolean",
        "null"
      ],
      "default": true,
      "description": "TEG branch is subordinate scavenging only; cannot erase downstream reject burden. 3B-spec \u00a78."
    }
  }
}