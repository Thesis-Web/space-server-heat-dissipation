{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "thermal-zone",
  "schema_version": "v0.3.0",
  "title": "ThermalZone",
  "description": "Thermal zone definition. v0.2.0 adds Extension 3A topology, resistance-chain, working-fluid, and pickup-geometry fields per 3A-spec §6. Backward-compat with v0.1.0 fields preserved. v0.3.0 adds Extension 3B vault_gas_environment_model, transport_implementation, and loop_model nested objects per 3B-spec §6.",
  "type": "object",
  "required": [
    "zone_id",
    "schema_version",
    "zone_label",
    "zone_type",
    "target_temp_k",
    "temp_min_k",
    "temp_max_k",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "zone_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "zone_label": {
      "type": "string",
      "description": "Human-readable zone label. SCHEMA-CONTRA-TZ-001: ANCHOR name wins over BASE 'label'."
    },
    "zone_type": {
      "type": "string",
      "enum": [
        "compute_vault",
        "hx_boundary",
        "high_temp_backbone",
        "radiator_emitter",
        "custom"
      ]
    },
    "target_temp_k": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "temp_min_k": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "temp_max_k": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "pressure_min_pa": {
      "type": "number",
      "minimum": 0
    },
    "pressure_max_pa": {
      "type": "number",
      "minimum": 0
    },
    "zone_subtype": {
      "type": "string",
      "enum": [
        "controlled_compute_vault",
        "chipset_pickup_stage1",
        "low_gradient_loop",
        "eutectic_exchange_hub",
        "regen_hot_island",
        "active_hot_island",
        "radiator_service_domain",
        "payload_emitter_zone",
        "branch_sink_zone",
        "custom"
      ]
    },
    "pickup_geometry": {
      "type": "string"
    },
    "service_role": {
      "type": "string",
      "enum": [
        "pickup",
        "transport",
        "exchange",
        "storage",
        "rejection",
        "payload",
        "branch_sink",
        "custom"
      ]
    },
    "material_family_ref": {
      "type": "string"
    },
    "coupled_zone_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "topology_role": {
      "type": "string"
    },
    "research_required": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    },
    "zone_role": {
      "type": "string",
      "enum": [
        "compute_vault",
        "hx_boundary",
        "high_temp_backbone",
        "radiator_emitter",
        "convergence_exchange",
        "custom"
      ],
      "description": "3A topology role for this zone. §6.2."
    },
    "flow_direction": {
      "type": "string",
      "enum": [
        "source",
        "sink",
        "bidirectional",
        "isolated"
      ],
      "default": "isolated",
      "description": "Declared flow direction for this zone. §6.3. Default: isolated."
    },
    "isolation_boundary": {
      "type": "boolean",
      "default": false,
      "description": "Whether this zone declares a thermal isolation boundary. §6.1."
    },
    "upstream_zone_ref": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "zone_id of the upstream neighbor zone. §6.1. Must not equal zone_id."
    },
    "downstream_zone_ref": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "zone_id of the downstream neighbor zone. §6.1. Must not equal zone_id."
    },
    "bridge_resistance_k_per_w": {
      "type": [
        "number",
        "null"
      ],
      "default": null,
      "exclusiveMinimum": 0,
      "description": "Thermal resistance of isolation bridge in K/W. Required when isolation_boundary=true. §6.4, §11.2."
    },
    "working_fluid_ref": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "ID of the working fluid from the working-fluid catalog. §6.1, §7."
    },
    "pickup_geometry_ref": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "ID of the pickup geometry from the pickup-geometry catalog. §6.1, §8."
    },
    "convergence_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether this zone participates in convergence iteration. Required true when zone_role=convergence_exchange. §6.4."
    },
    "resistance_chain": {
      "type": [
        "object",
        "null"
      ],
      "default": null,
      "description": "Junction-to-sink resistance chain sub-object. §6.5.",
      "additionalProperties": false,
      "properties": {
        "r_junction_to_case_k_per_w": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "r_case_to_spreader_k_per_w": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "r_spreader_to_pickup_nominal_k_per_w": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "r_pickup_to_loop_k_per_w": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "r_loop_to_sink_k_per_w": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "vault_gas_environment_model": {
      "type": [
        "object",
        "null"
      ],
      "default": null,
      "description": "3B vault gas environment model nested object. Spec §6.1.",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "preset",
            "custom"
          ],
          "default": "none"
        },
        "preset_id": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "preset_version": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "gas_presence_mode": {
          "type": "string",
          "enum": [
            "none",
            "trace_fill",
            "pressurized",
            "custom"
          ],
          "default": "none"
        },
        "gas_species_ref": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "pressure_pa": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "default": null
        },
        "convection_assumption_mode": {
          "type": "string",
          "enum": [
            "disabled",
            "operator_fixed_h",
            "preset_fixed_h",
            "custom"
          ],
          "default": "disabled"
        },
        "effective_h_internal_w_per_m2_k": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "default": null
        },
        "exchange_area_m2": {
          "type": [
            "number",
            "null"
          ],
          "exclusiveMinimum": 0,
          "default": null
        },
        "contamination_outgassing_mode": {
          "type": "string",
          "enum": [
            "none",
            "nominal_clean",
            "elevated_unknown",
            "custom"
          ],
          "default": "none"
        },
        "manual_override_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "notes": {
          "type": "string",
          "default": ""
        }
      }
    },
    "transport_implementation": {
      "type": [
        "object",
        "null"
      ],
      "default": null,
      "description": "3B transport implementation object. Spec §6.2.",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "preset",
            "custom"
          ],
          "default": "none"
        },
        "preset_id": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "preset_version": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "transport_class": {
          "type": "string",
          "enum": [
            "passive",
            "pumped_single_phase_liquid",
            "pumped_gas",
            "two_phase_managed",
            "custom"
          ],
          "default": "passive"
        },
        "pump_model_mode": {
          "type": "string",
          "enum": [
            "none",
            "direct_power",
            "pressure_drop_flow",
            "preset",
            "custom"
          ],
          "default": "none"
        },
        "pump_power_input_w": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "default": null
        },
        "pump_efficiency_fraction": {
          "type": [
            "number",
            "null"
          ],
          "exclusiveMinimum": 0,
          "maximum": 1,
          "default": null
        },
        "pressure_drop_pa": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "default": null
        },
        "mass_flow_kg_per_s": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "default": null
        },
        "fluid_density_kg_per_m3_override": {
          "type": [
            "number",
            "null"
          ],
          "exclusiveMinimum": 0,
          "default": null
        },
        "gas_management_mode": {
          "type": "string",
          "enum": [
            "not_applicable",
            "single_phase_intended",
            "gas_managed",
            "custom"
          ],
          "default": "not_applicable"
        },
        "allowable_void_fraction": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1,
          "default": null
        },
        "declared_void_fraction": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1,
          "default": null
        },
        "bubble_blanketing_penalty_fraction": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1,
          "default": null
        },
        "gas_lock_flow_derate_fraction": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1,
          "default": null
        },
        "separator_type": {
          "type": "string",
          "enum": [
            "none",
            "membrane",
            "vortex",
            "capillary_trap",
            "reservoir",
            "custom"
          ],
          "default": "none"
        },
        "notes": {
          "type": "string",
          "default": ""
        }
      }
    },
    "loop_model": {
      "type": [
        "object",
        "null"
      ],
      "default": null,
      "description": "3B loop aggregation object. Aggregation only; no primitive pump ownership. Spec §6.3.",
      "additionalProperties": false,
      "properties": {
        "loop_id": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "upstream_loop_ref": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "downstream_loop_ref": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "derived_total_parasitic_w": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "default": null
        },
        "derived_effective_loop_resistance_addition_k_per_w": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "default": null
        },
        "notes": {
          "type": "string",
          "default": ""
        }
      }
    },
    "chain_id": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "Fluid loop circuit identity. Zone chain spec v0.1.2 §2.1. Zones without chain_id connect freely (ZC-002)."
    },
    "loop_role": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "cold_loop",
        "hot_island",
        "hot_backbone",
        "regen_loop",
        "radiator_loop",
        "safety_loop",
        "custom",
        null
      ],
      "default": null,
      "description": "Semantic role of the fluid loop this zone belongs to. Distinct from zone_role. Zone chain spec v0.1.2 §2.2."
    },
    "hot_island_role": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "Hot island role of this zone. Added session 6 UI patch."
    }
  }
}