{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "run-packet",
  "schema_version": "v0.2.0",
  "title": "RunPacket",
  "description": "Deterministic handoff artifact from browser UI to hub AI workflow. Governed by \u00a725. UI-expansion additive fields per ui-expansion-spec-v0.1.5. SCHEMA-CONTRA-RP-001: branch_selection_summary ANCHOR=object, BASE=string; ANCHOR wins. SCHEMA-CONTRA-RP-002: ai_role_instructions ANCHOR=object, BASE=string; ANCHOR wins. SCHEMA-CONTRA-RP-003 RESOLVED: file_manifest item key is name per ui-expansion-spec-v0.1.5 \u00a7180.",
  "type": "object",
  "required": [
    "packet_id",
    "schema_version",
    "blueprint_version",
    "engineering_spec_version",
    "scenario_ref",
    "payload_file_refs",
    "operator_notes",
    "requested_outputs",
    "branch_selection_summary",
    "comparison_requests",
    "ai_role_instructions"
  ],
  "additionalProperties": false,
  "properties": {
    "packet_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "blueprint_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "engineering_spec_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "runtime_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "schema_bundle_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "scenario_ref": {
      "type": "string",
      "description": "Filename of the primary scenario JSON in this bundle."
    },
    "payload_file_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "All payload filenames included in this bundle."
    },
    "operator_notes": {
      "type": "string"
    },
    "requested_outputs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "structured_json",
          "summary_markdown",
          "comparison_report",
          "flag_report",
          "packet_bundle"
        ]
      }
    },
    "branch_selection_summary": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "description": "Map of branch_id to enabled boolean. SCHEMA-CONTRA-RP-001: ANCHOR wins over BASE string type."
    },
    "comparison_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "base_scenario_ref",
          "variant_scenario_ref"
        ],
        "properties": {
          "base_scenario_ref": {
            "type": "string"
          },
          "variant_scenario_ref": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "ai_role_instructions": {
      "type": "object",
      "properties": {
        "claude_instructions": {
          "type": "string"
        },
        "chatgpt_instructions": {
          "type": "string"
        },
        "perplexity_instructions": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "description": "SCHEMA-CONTRA-RP-002: ANCHOR wins over BASE string type."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "file_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "byte_length"
        ],
        "properties": {
          "byte_length": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "description": "Integrity manifest per \u00a737.3. SCHEMA-CONTRA-RP-003: key is filename (ANCHOR) not name (BASE)."
    },
    "runtime_authority_declaration": {
      "type": "string",
      "const": "runtime",
      "description": "Carried from BASE v0.1.5 per ui-expansion-spec-v0.1.5."
    },
    "catalog_ids_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "catalog_versions_used": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "catalog_checksums_sha256": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "transform_trace": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "branding_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "validation_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "risk_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "research_required_items": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of items flagged research-required per spec \u00a716.1."
    },
    "enable_model_extension_2": {
      "type": "boolean",
      "default": false,
      "description": "Extension 2 enable state serialized into packet per spec \u00a716.1."
    },
    "model_extension_2_mode": {
      "type": "string",
      "enum": [
        "disabled",
        "baseline_only",
        "exploratory_compare",
        "exploratory_only"
      ],
      "default": "disabled",
      "description": "Extension 2 mode serialized into packet per spec \u00a716.1."
    },
    "source_spectral_profile_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "All source spectral profile catalog IDs used per spec \u00a716.1."
    },
    "derived_source_profiles": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Derived source profiles with derivation basis per spec \u00a716.1 and \u00a76.5."
    },
    "spectral_stage_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "All spectral stage IDs in packet per spec \u00a716.1."
    },
    "extension_2_catalog_ids_used": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "All Extension 2 catalog entry IDs used per spec \u00a716.1."
    },
    "extension_2_catalog_versions_used": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of catalog name to version string per spec \u00a716.1."
    },
    "extension_2_catalog_checksums_sha256": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of catalog name to SHA-256 checksum per spec \u00a716.1."
    },
    "exploratory_result_policy": {
      "type": "string",
      "enum": [
        "do_not_mix",
        "emit_delta_only",
        "emit_parallel_result"
      ],
      "description": "Serialized exploratory result policy per spec \u00a716.1."
    },
    "research_packet_intent": {
      "type": "string",
      "enum": [
        "engineering_trade",
        "research_screen",
        "bench_candidate",
        "custom"
      ],
      "description": "Serialized research packet intent per spec \u00a716.1."
    },
    "strict_research_enforcement": {
      "type": "boolean",
      "description": "Serialized strict research enforcement flag per spec \u00a716.1."
    },
    "exploratory_coefficients_summary": {
      "type": "object",
      "description": "Summary object of all exploratory coefficients used per spec \u00a716.1."
    },
    "baseline_result": {
      "type": "object",
      "description": "Baseline result section per spec \u00a716.2. Required when extension 2 is active."
    },
    "exploratory_result": {
      "type": "object",
      "description": "Exploratory result section per spec \u00a716.2. Emitted when mode = exploratory_compare or exploratory_only."
    },
    "delta_result": {
      "type": "object",
      "description": "Delta result section per spec \u00a716.2. Emitted when mode = exploratory_compare."
    },
    "extension_2_summary": {
      "type": "object",
      "description": "Extension 2 overall summary object per spec \u00a716.2."
    },
    "extension_2_stage_results": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Per-stage exploratory result objects per spec \u00a716.2."
    },
    "enable_model_extension_3a": {
      "type": "boolean",
      "default": false,
      "description": "3A enable gate mirrored from scenario. \u00a75.1."
    },
    "model_extension_3a_mode": {
      "type": "string",
      "enum": [
        "disabled",
        "topology_only",
        "foundational_hardening"
      ],
      "default": "disabled",
      "description": "3A mode mirrored from scenario. \u00a75.2."
    },
    "topology_report_policy": {
      "type": "string",
      "enum": [
        "always",
        "on_warning",
        "never"
      ],
      "default": "always",
      "description": "3A topology report emission policy per \u00a710.1."
    },
    "defaults_audit_version": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "3A defaults audit artifact version. \u00a710.1."
    },
    "extension_3a_catalog_versions": {
      "type": [
        "object",
        "null"
      ],
      "default": null,
      "description": "3A catalog version references per \u00a710.1.",
      "additionalProperties": false,
      "properties": {
        "working_fluids": {
          "type": [
            "string",
            "null"
          ]
        },
        "pickup_geometries": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "extension_3a_result": {
      "type": [
        "object",
        "null"
      ],
      "default": null,
      "description": "3A runtime structured result. Contains topology, convergence, resistance, radiator BOL/EOL, radiation-pressure outputs per \u00a714.1."
    },
    "extension_3a_topology_report": {
      "type": [
        "object",
        "null"
      ],
      "default": null,
      "description": "3A topology report emitter output. \u00a714, topology-report.ts."
    }
  }
}