{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "scenario",
  "schema_version": "v0.2.0",
  "title": "Scenario",
  "description": "Top-level orchestration schema for an orbital thermal trade scenario. Governed by \u00a715 of engineering spec v0.1.0. UI-expansion additive fields per ui-expansion-spec-v0.1.5. SCHEMA-CONTRA-SC-001/002/003/004 logged \u2014 see field-level comments. v0.2.0 adds Extension 3A fields: enable_model_extension_3a, model_extension_3a_mode, thermal_zones[], topology_validation_policy, convergence_control, defaults_audit_version. Extension-2 fields preserved.",
  "type": "object",
  "required": [
    "scenario_id",
    "schema_version",
    "scenario_version",
    "label",
    "orbit_class",
    "environment_profile",
    "mission_mode",
    "node_class",
    "architecture_class",
    "utilization_profile",
    "thermal_policy",
    "selected_branches",
    "reporting_preferences"
  ],
  "additionalProperties": false,
  "properties": {
    "scenario_id": {
      "type": "string",
      "description": "Stable identifier for one run definition."
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$",
      "description": "Schema contract version."
    },
    "scenario_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$",
      "description": "Operator-authored scenario revision."
    },
    "label": {
      "type": "string",
      "description": "Human-readable scenario label."
    },
    "orbit_class": {
      "type": "string",
      "enum": [
        "GEO"
      ],
      "description": "Must be GEO in v0.1.0 per \u00a77.3. SCHEMA-CONTRA-SC-003: BASE allowed MEO/LEO/HEO; spec \u00a77.3 GEO-only governs."
    },
    "environment_profile": {
      "description": "Inline environment object or named reference string.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "solar_absorbed_w": {
              "type": "number",
              "minimum": 0
            },
            "earth_reflected_w": {
              "type": "number",
              "minimum": 0
            },
            "earth_ir_w": {
              "type": "number",
              "minimum": 0
            },
            "eclipse_fraction": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "background_sink_k": {
              "type": "number",
              "minimum": 0
            },
            "user_margin_w": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "mission_mode": {
      "type": "string",
      "enum": [
        "compute_only",
        "compute_plus_communications",
        "communications_only",
        "custom"
      ],
      "description": "SCHEMA-CONTRA-SC-002: BASE used full_compute/burst/standby/eclipse/safe_mode; ANCHOR values govern."
    },
    "node_class": {
      "type": "string",
      "enum": [
        "50kw",
        "300kw",
        "1mw",
        "custom"
      ],
      "description": "SCHEMA-CONTRA-SC-001: BASE used node_s_50kw/node_m_100kw/node_l_1mw; ANCHOR values govern."
    },
    "architecture_class": {
      "type": "string",
      "description": "Descriptive architecture label (e.g. cold_loop_plus_hot_backbone)."
    },
    "utilization_profile": {
      "type": "string",
      "description": "Named or custom duty family (idle, light, medium, full, custom)."
    },
    "thermal_policy": {
      "type": "string",
      "enum": [
        "conservative",
        "nominal",
        "aggressive",
        "experimental"
      ],
      "description": "SCHEMA-CONTRA-SC-004: BASE used thermal_policy_id (string, no enum); ANCHOR field name and enum govern."
    },
    "selected_branches": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "none",
          "reverse_brayton",
          "brayton_power_cycle",
          "stirling",
          "tpv",
          "teg",
          "rf_export",
          "laser_export",
          "custom"
        ]
      }
    },
    "reporting_preferences": {
      "type": "object",
      "required": [
        "summary_markdown",
        "comparison_enabled"
      ],
      "properties": {
        "summary_markdown": {
          "type": "boolean"
        },
        "comparison_enabled": {
          "type": "boolean"
        },
        "comparison_scenario_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "include_assumptions": {
          "type": "boolean"
        },
        "include_flags": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "compute_module_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "References to compute-module payload files."
    },
    "communications_payload_ref": {
      "type": "string",
      "description": "Reference to communications-payload file."
    },
    "thermal_zone_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "thermal_stage_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "radiator_ref": {
      "type": "string"
    },
    "storage_ref": {
      "type": "string"
    },
    "working_fluid_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conversion_branch_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operator_notes": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scenario_preset_id": {
      "type": "string"
    },
    "scenario_preset_version": {
      "type": "string"
    },
    "catalog_versions_used": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "catalog_checksums_sha256": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "branch_block_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "non_compute_payload_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "material_family_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "topology_ref": {
      "type": "string"
    },
    "generated_aggregate_payload_ref": {
      "type": "string"
    },
    "transform_trace": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "research_required_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "thermal_policy_id": {
      "type": "string",
      "description": "UI layer alias for thermal_policy per ui-expansion-spec-v0.1.5 \u00a7133. Optional. Runtime uses thermal_policy enum."
    },
    "enable_model_extension_2": {
      "type": "boolean",
      "default": false,
      "description": "Extension 2 enable gate per model-extension-2-spec-v0.2.1 \u00a75.1. If false, all Extension 2 fields must be absent, null, empty, or ignored."
    },
    "model_extension_2_mode": {
      "type": "string",
      "enum": [
        "disabled",
        "baseline_only",
        "exploratory_compare",
        "exploratory_only"
      ],
      "default": "disabled",
      "description": "Extension 2 operating mode per spec \u00a75.2."
    },
    "source_spectral_profile_ref": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "Reference to a source spectral profile catalog entry per spec \u00a75.1."
    },
    "spectral_stage_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Array of spectral stage IDs active in this scenario per spec \u00a75.1."
    },
    "exploratory_result_policy": {
      "type": "string",
      "enum": [
        "do_not_mix",
        "emit_delta_only",
        "emit_parallel_result"
      ],
      "default": "do_not_mix",
      "description": "Controls how exploratory results are emitted per spec \u00a75.2."
    },
    "research_packet_intent": {
      "type": "string",
      "enum": [
        "engineering_trade",
        "research_screen",
        "bench_candidate",
        "custom"
      ],
      "default": "engineering_trade",
      "description": "Declares downstream intent of packet per spec \u00a75.2."
    },
    "strict_research_enforcement": {
      "type": "boolean",
      "default": true,
      "description": "When true, placeholder or hypothesis_only provenance on output-driving fields raises blocking caution per spec \u00a712.5."
    },
    "enable_model_extension_3a": {
      "type": "boolean",
      "default": false,
      "description": "Extension 3A enable gate per 3A-spec \u00a75.1. If false, all 3A fields are absent/null/ignored. Backward-compat: absent field treated as false per \u00a75.3."
    },
    "model_extension_3a_mode": {
      "type": "string",
      "enum": [
        "disabled",
        "topology_only",
        "foundational_hardening"
      ],
      "default": "disabled",
      "description": "Extension 3A operating mode per 3A-spec \u00a75.2."
    },
    "thermal_zones": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": [],
      "description": "3A canonical thermal zone objects array. Compiled from UI additive blocks. Per 3A-spec \u00a75.1, \u00a76. Coexists with thermal_zone_refs (id references)."
    },
    "topology_validation_policy": {
      "type": "string",
      "enum": [
        "blocking",
        "warn_only"
      ],
      "default": "blocking",
      "description": "3A topology validation policy. \u00a75.1\u2013\u00a75.2, \u00a713.1."
    },
    "convergence_control": {
      "type": [
        "object",
        "null"
      ],
      "default": null,
      "description": "3A convergence control parameters per \u00a75.4.",
      "additionalProperties": false,
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "default": 25
        },
        "tolerance_abs_w": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 1.0
        },
        "tolerance_rel_fraction": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1,
          "default": 0.001
        },
        "runaway_multiplier": {
          "type": "number",
          "minimum": 2.0,
          "default": 4.0
        },
        "blocking_on_nonconvergence": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "defaults_audit_version": {
      "type": [
        "string",
        "null"
      ],
      "default": null,
      "description": "3A defaults audit artifact version reference. \u00a75.1, \u00a710.1."
    }
  }
}